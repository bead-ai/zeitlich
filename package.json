{
  "name": "zeitlich",
  "version": "0.2.20",
  "description": "[EXPERIMENTAL] An opinionated AI agent implementation for Temporal",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./workflow": {
      "import": {
        "types": "./dist/workflow.d.ts",
        "default": "./dist/workflow.js"
      },
      "require": {
        "types": "./dist/workflow.d.ts",
        "default": "./dist/workflow.js"
      }
    },
    "./adapters/thread/langchain": {
      "import": {
        "types": "./dist/adapters/thread/langchain/index.d.ts",
        "default": "./dist/adapters/thread/langchain/index.js"
      },
      "require": {
        "types": "./dist/adapters/thread/langchain/index.d.ts",
        "default": "./dist/adapters/thread/langchain/index.js"
      }
    },
    "./adapters/thread/google-genai": {
      "import": {
        "types": "./dist/adapters/thread/google-genai/index.d.ts",
        "default": "./dist/adapters/thread/google-genai/index.js"
      },
      "require": {
        "types": "./dist/adapters/thread/google-genai/index.d.ts",
        "default": "./dist/adapters/thread/google-genai/index.js"
      }
    },
    "./adapters/sandbox/inmemory": {
      "import": {
        "types": "./dist/adapters/sandbox/inmemory/index.d.ts",
        "default": "./dist/adapters/sandbox/inmemory/index.js"
      },
      "require": {
        "types": "./dist/adapters/sandbox/inmemory/index.d.ts",
        "default": "./dist/adapters/sandbox/inmemory/index.js"
      }
    },
    "./adapters/sandbox/virtual": {
      "import": {
        "types": "./dist/adapters/sandbox/virtual/index.d.ts",
        "default": "./dist/adapters/sandbox/virtual/index.js"
      },
      "require": {
        "types": "./dist/adapters/sandbox/virtual/index.d.ts",
        "default": "./dist/adapters/sandbox/virtual/index.js"
      }
    },
    "./adapters/sandbox/daytona": {
      "import": {
        "types": "./dist/adapters/sandbox/daytona/index.d.ts",
        "default": "./dist/adapters/sandbox/daytona/index.js"
      },
      "require": {
        "types": "./dist/adapters/sandbox/daytona/index.d.ts",
        "default": "./dist/adapters/sandbox/daytona/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "tsup.config.ts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "prepack": "npm run build",
    "release:pr": "release-please release-pr --repo-url=bead-ai/zeitlich --token=$GITHUB_TOKEN",
    "release:pr:dry": "release-please release-pr --repo-url=bead-ai/zeitlich --token=$GITHUB_TOKEN --dry-run",
    "release:github": "release-please github-release --repo-url=bead-ai/zeitlich --token=$GITHUB_TOKEN",
    "release:npm": "npm publish --access public",
    "release:publish": "npm run release:github && npm run release:npm"
  },
  "keywords": [
    "ai",
    "temporal",
    "agent",
    "sdk",
    "agent"
  ],
  "author": "Bead Technologies Inc. <founders@usebead.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bead-ai/zeitlich.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@daytonaio/sdk": "^0.149.0",
    "@e2b/code-interpreter": "^2.3.3",
    "@eslint/js": "^10.0.1",
    "@google/genai": "^1.44.0",
    "@langchain/core": "^1.1.30",
    "@temporalio/envconfig": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "just-bash": "^2.12.8",
    "prettier": "^3.8.1",
    "release-please": "^17.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@daytonaio/sdk": ">=0.100.0",
    "@e2b/code-interpreter": "^2.3.3",
    "@google/genai": "^1.43.0",
    "@langchain/core": ">=1.0.0",
    "ioredis": ">=5.0.0",
    "just-bash": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@daytonaio/sdk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "just-bash": {
      "optional": true
    }
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/bead-ai/zeitlich/issues"
  },
  "homepage": "https://github.com/bead-ai/zeitlich#readme",
  "dependencies": {
    "@temporalio/common": "^1.15.0",
    "@temporalio/plugin": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "zod": "^4.3.6"
  }
}
